{
  "description": "Hyperparameter experiments for glass bottle defect classification.",
  "defaults": {
    "epochs": 30,
    "batch_size": 16,
    "image_size": 384,
    "weights": "imagenet",
    "device": "auto",
    "balance_strategy": "sampler",
    "model_selection_metric": "auprc",
    "freeze_backbone_epochs": 2,
    "early_stopping_patience": 5,
    "sample_level": "group",
    "group_view_suffixes": "26_2_C.bmp,28_2_C.bmp,80_2_C.bmp",
    "group_aggregation": "concat",
    "output_dir": "output/experiments"
  },
  "experiments": [
    {
      "name": "efficientnet_learning_rate",
      "args": {
        "model": "efficientnet_b0"
      },
      "grid": {
        "learning_rate": [0.0001, 0.0003, 0.001]
      }
    }
  ]
}
